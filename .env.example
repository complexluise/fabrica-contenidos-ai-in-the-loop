# Copia este archivo a .env y rellena tus claves. .env esta gitignored.
# Las lee pipeline/settings.py (pydantic-settings). Tambien valen variables de entorno reales.

# fal.ai — keyframe (Flux+LoRA) y video (Kling/Seedance...)
FAL_KEY=

# Anthropic — descomposicion de guion, clasificador y Quality Gate (VLM-judge). Opcional en local.
ANTHROPIC_API_KEY=

# Google — Veo (Sprint 2). Opcional por ahora.
GOOGLE_API_KEY=

# ElevenLabs — voz en off por escena (TTS, Sprint 6). Opcional (solo si usas `voiceover:`).
ELEVENLABS_API_KEY=
