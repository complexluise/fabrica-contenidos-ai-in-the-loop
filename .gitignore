projects/*/

# Node (conversor md->docx D-030; UI Svelte D-031)
node_modules/
*.docx
app/dist/

# Estado / DB
*.sqlite
*.sqlite3
*.db

# OS / editor
.DS_Store
Thumbs.db
.idea/
.vscode/

# Excepcion: lego_demo es el unico proyecto versionado (showcase curado).
# Solo la entrada, la decision humana y un resultado. El resto queda fuera:
# un `git add .` accidental nunca sube un proyecto privado.
!projects/lego_demo/README.md
!projects/lego_demo/project.yaml
!projects/lego_demo/selections.yaml
!projects/lego_demo/keyframe_s1.png
!projects/lego_demo/final_9x16.mp4

# Bundle distribuible (scripts/build.py): dist/ y build/ son artefactos
dist/
build/
# Espacio de trabajo de recortes (material generado, D-079 fix)
_recut/
